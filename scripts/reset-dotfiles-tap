#!/usr/bin/env bash
# Retarget the civitaspo/dotfiles Homebrew tap at this checkout and sync it.
#
# brew bundle skips already-installed taps, so a stale clone can miss new
# files under Casks/. Homebrew 6 also keys tap trust to the custom remote
# path from Brewfile `__dir__`, so keep origin equal to this checkout.
# If the installed tap checkout is corrupt (e.g. a deleted git worktree),
# force-untap and clone again.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TAP="civitaspo/dotfiles"
BREW="/opt/homebrew/bin/brew"
export PATH="/opt/homebrew/bin:$PATH"

# Match Brewfile `__dir__` (logical path, not realpath) so trusted: true applies.
repo_root="$REPO_ROOT"

tap_git_ok() {
  local tap_path="$1"
  [ -e "$tap_path" ] && git -C "$tap_path" rev-parse --git-dir >/dev/null 2>&1
}

force_retap() {
  if "$BREW" tap | grep -qx "$TAP"; then
    "$BREW" untap --force "$TAP" || true
  fi
  # untap can leave a broken checkout behind when .git itself is invalid.
  local tap_path
  tap_path="$("$BREW" --repo "$TAP" 2>/dev/null || true)"
  if [ -n "$tap_path" ] && [ -e "$tap_path" ]; then
    rm -rf "$tap_path"
  fi
  "$BREW" tap --custom-remote "$TAP" "$repo_root"
}

if ! "$BREW" tap | grep -qx "$TAP"; then
  "$BREW" tap --custom-remote "$TAP" "$repo_root"
else
  tap_path="$("$BREW" --repo "$TAP")"
  if ! tap_git_ok "$tap_path"; then
    force_retap
  else
    remote="$(git -C "$tap_path" remote get-url origin 2>/dev/null || true)"
    if [ "${remote%/}" != "${repo_root%/}" ]; then
      if ! "$BREW" tap --custom-remote "$TAP" "$repo_root"; then
        force_retap
      fi
    fi
  fi
fi

tap_path="$("$BREW" --repo "$TAP")"
if ! tap_git_ok "$tap_path"; then
  force_retap
  tap_path="$("$BREW" --repo "$TAP")"
fi

head_sha="$(git -C "$repo_root" rev-parse HEAD)"
git -C "$tap_path" fetch --quiet origin
git -C "$tap_path" reset --hard --quiet "$head_sha"

# Name-based trust does not match a custom-remote tap; trust the path remote.
"$BREW" trust "$(git -C "$tap_path" remote get-url origin)"
