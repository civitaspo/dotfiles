#!/usr/bin/env bash
# Point the civitaspo/dotfiles Homebrew tap at this checkout and sync it.
#
# brew bundle skips already-installed taps, so a stale clone never picks up
# new files under Casks/. Retarget the remote when needed, then hard-reset
# the tap working tree to this repository's HEAD before Brewfile applies.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TAP="civitaspo/dotfiles"
BREW="/opt/homebrew/bin/brew"
export PATH="/opt/homebrew/bin:$PATH"

repo_root="$REPO_ROOT"
# Prefer the physical path so comparisons match git remote get-url.
if command -v realpath >/dev/null 2>&1; then
  repo_root="$(realpath "$REPO_ROOT")"
fi

normalize_path() {
  local path="$1"
  if [ -d "$path" ] && command -v realpath >/dev/null 2>&1; then
    realpath "$path"
  else
    printf '%s\n' "${path%/}"
  fi
}

ensure_local_tap() {
  if ! "$BREW" tap | grep -qx "$TAP"; then
    "$BREW" tap --custom-remote "$TAP" "$repo_root"
  else
    local tap_path remote
    tap_path="$("$BREW" --repo "$TAP")"
    remote="$(git -C "$tap_path" remote get-url origin 2>/dev/null || true)"
    if [ "$(normalize_path "$remote")" != "$(normalize_path "$repo_root")" ]; then
      "$BREW" tap --custom-remote "$TAP" "$repo_root"
    fi
  fi

  local tap_path head_sha
  tap_path="$("$BREW" --repo "$TAP")"
  head_sha="$(git -C "$repo_root" rev-parse HEAD)"
  git -C "$tap_path" fetch --quiet origin
  git -C "$tap_path" reset --hard --quiet "$head_sha"
}

ensure_local_tap
"$BREW" bundle --file "$REPO_ROOT/Brewfile" --force-cleanup
